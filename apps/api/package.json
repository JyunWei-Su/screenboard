{
  "name": "@screenboard/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply screenboard --local",
    "migrate:remote": "wrangler d1 migrations apply screenboard --remote",
    "seed:local": "wrangler d1 execute screenboard --local --file=./seed.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@screenboard/shared": "*",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.99.0"
  }
}
